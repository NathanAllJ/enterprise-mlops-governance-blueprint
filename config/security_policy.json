{
  "$schema": "json-schema.org",
  "policy_metadata": {
    "organization": "Enterprise Healthcare & Analytics Corp",
    "policy_version": "2.4.0",
    "last_audited_timestamp": "2026-05-14T12:00:00Z",
    "compliance_targets": ["GDPR", "HIPAA", "SOC2-TypeII"]
  },
  "data_privacy_controls": {
    "pii_masking_strategy": "SHA256_SALTED_HASH",
    "salt_environment_variable": "PII_HASH_SALT",
    "restricted_fields": ["email", "ssn", "patient_name", "phone_number"],
    "quasi_identifiers": ["zip_code", "date_of_birth"]
  },
  "ml_model_guardrails": {
    "minimum_acceptable_f1_score": 0.85,
    "maximum_data_drift_p_value": 0.05,
    "explainability_engine": "SHAP",
    "bias_monitoring": {
      "protected_attributes": ["age", "gender"],
      "disparate_impact_threshold": 0.80
    }
  },
  "runtime_incident_routing": {
    "actionable_risk_tiers": {
      "LOW": {
        "action": "AUTO_APPROVE",
        "requires_human_review": false
      },
      "MEDIUM": {
        "action": "FLAG_FOR_AUDIT",
        "requires_human_review": true,
        "review_team": "compliance-tier-1"
      },
      "HIGH": {
        "action": "BLOCK_TRANSACTION",
        "requires_human_review": true,
        "review_team": "risk-operations-director"
      }
    }
  }
}

