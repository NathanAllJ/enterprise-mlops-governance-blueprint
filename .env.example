# ==============================================================================
# 🏢 ENTERPRISE ML PLATFORM RUNTIME CONFIGURATION TEMPLATE
# ==============================================================================
# INSTRUCTIONS: Copy this file to a new file named '.env' and fill in your values.
# NEVER commit the actual '.env' file containing real secrets to version control.

# 1. Core Application Environment
APP_ENV=development             # Options: development, staging, production
DEBUG_MODE=true                 # Set to 'false' in production environments
API_BIND_HOST=0.0.0.0
API_BIND_PORT=8000

# 2. Cryptographic Privacy Keys
# Used by data_pipeline/anonymizer.py to generate secure, un-reversible hashes
PII_HASH_SALT=your_company_secure_rotating_salt_key_goes_here

# 3. Enterprise Storage & Database Connectivity
# Example: postgresql://db_user:db_password@host:5432/database_name
DATABASE_URL=postgresql://db_user:placeholder_password@localhost:5432/enterprise_ml_db
S3_ARTIFACT_BUCKET=enterprise-mlops-registry-prod

# 4. Model Registry Auditing Metrics
CURRENT_PRODUCTION_VERSION=1.0.0
COMPLIANCE_LOG_PATH=/var/log/enterprise_ml/compliance_audit.log

